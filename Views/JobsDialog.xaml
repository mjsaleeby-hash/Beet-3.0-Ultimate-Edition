<Window x:Class="BeetsBackup.Views.JobsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scheduled Jobs"
        Width="640" Height="400"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        FontFamily="Segoe UI Variable, Segoe UI"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scheduled Backup Jobs"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>

        <!-- Jobs list -->
        <ListView Grid.Row="2" x:Name="JobsList"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  MouseDoubleClick="JobsList_MouseDoubleClick">
            <!-- Override the default selection style so the row text stays readable on the accent highlight.
                 Without this, WPF's default ListViewItem keeps the unselected Foreground, which can
                 wash out against the selection background. -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="140" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Source" Width="140" DisplayMemberBinding="{Binding SourcePathsDisplay}"/>
                    <GridViewColumn Header="Destination" Width="140" DisplayMemberBinding="{Binding DestinationPath}"/>
                    <GridViewColumn Header="Next Run" Width="140" DisplayMemberBinding="{Binding NextRun}"/>
                    <GridViewColumn Header="Recurring" Width="80" DisplayMemberBinding="{Binding IsRecurring}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Edit Selected"
                    Background="{DynamicResource PanelBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Padding="16,8" Margin="0,0,12,0" Cursor="Hand"
                    Click="Edit_Click"/>
            <Button Content="Delete Selected"
                    Background="{DynamicResource PanelBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Padding="16,8" Margin="0,0,12,0" Cursor="Hand"
                    Click="Delete_Click"/>
            <Button Content="Close"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Padding="16,8" Cursor="Hand"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
