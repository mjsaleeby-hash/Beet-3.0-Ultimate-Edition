<Window x:Class="BeetsBackup.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BeetsBackup.ViewModels"
        xmlns:m="clr-namespace:BeetsBackup.Models"
        xmlns:h="clr-namespace:BeetsBackup.Helpers"
        xmlns:views="clr-namespace:BeetsBackup.Views"
        Title="Beet's Backup"
        Icon="/Assets/Beets Backup IMG.ico"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="750"
        FontSize="14"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <h:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <h:UsageToArcConverter x:Key="UsageToArcConverter"/>
        <h:RelativeDateConverter x:Key="RelativeDateConverter"/>
        <h:PercentToWidthConverter x:Key="PercentToWidthConverter"/>

        <!-- ================================================================
             SCROLLBAR: Slim 6px modern scrollbars
             ================================================================ -->
        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ================================================================
             TREE TEMPLATE: drive nodes show usage bar, subfolders show name
             ================================================================ -->
        <HierarchicalDataTemplate x:Key="FolderTreeTemplate" ItemsSource="{Binding Children}">
            <Grid>
                <!-- Drive row: rounded uniform tile w/ icon + name + ring. Explicit width
                     because TreeViewItem's default template doesn't propagate stretch. -->
                <Border Visibility="{Binding IsDrive, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="#3A3075" BorderThickness="1"
                        CornerRadius="10" Padding="10,8" Margin="0,3,4,3"
                        Width="190" Height="58"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Hard-drive glyph -->
                        <TextBlock Grid.Column="0" Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,9,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding DriveInfo.UsedSpaceDisplay, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding DriveInfo.TotalSizeDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Ring + % badge. Path forced to 30x30 to match UsageToArcConverter's
                             coordinate space (center=15,15); otherwise the arc's bounding box
                             shrinks with %, offsetting its center from the Ellipse center. -->
                        <Grid Grid.Column="2" Width="36" Height="36" Margin="6,0,0,0"
                              VerticalAlignment="Center" ToolTip="{Binding DriveInfo.FreeSpaceDisplay}">
                            <Ellipse Width="30" Height="30"
                                     Stroke="{DynamicResource RingTrackBrush}" StrokeThickness="3" Fill="Transparent"/>
                            <Path Width="30" Height="30"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="{Binding DriveInfo.UsagePercent, Converter={StaticResource UsageToArcConverter}}"
                                  Fill="Transparent"/>
                            <TextBlock Text="{Binding DriveInfo.UsagePercent, StringFormat={}{0:F0}%}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="9.5" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Folder row: plain text -->
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14"
                           Visibility="{Binding IsDrive, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            </Grid>
        </HierarchicalDataTemplate>

        <!-- ================================================================
             TREEVIEW STYLING
             ================================================================ -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                 Color="{DynamicResource SelectionColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                 Color="{DynamicResource PrimaryTextColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                 Color="{DynamicResource SelectionColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                 Color="{DynamicResource PrimaryTextColor}"/>
            </Style.Resources>
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ================================================================
             LISTBOX ITEM
             ================================================================ -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================================================================
             LISTVIEW ITEM: 28px compact rows, accent left-border on selection
             Background is {x:Null} so dead-zone right of last column is NOT
             hit-testable — prevents accidental selection near scrollbar.
             ================================================================ -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="2,0,0,0" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Margin="0,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================================================================
             TOOLBAR BUTTON: CornerRadius 8, transparent bg, pill hover
             Sized to match header.png reference (~38px tall, generous padding)
             ================================================================ -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button: accent-dim bg with accent border -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Danger button: red tint for Stop -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- Icon-only button (square, compact) -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="MinWidth" Value="30"/>
        </Style>

        <!-- Nav bar button (compact) -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <!-- ================================================================
             TOGGLE SWITCH: Replaces checkbox for toolbar options
             ================================================================ -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="{DynamicResource ToggleTrackOffBrush}"
                                    CornerRadius="9"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ToggleTrackOffBrush}"/>
                            <Ellipse x:Name="Knob"
                                     Width="12" Height="12"
                                     Fill="{DynamicResource SecondaryTextBrush}"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Knob" Property="Fill" Value="White"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================================================================
             GRIDVIEW COLUMN HEADER: modern, subtle
             ================================================================ -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================================================================
             TEXTBOX STYLE: rounded, themed for nav/search bars
             ================================================================ -->
        <Style x:Key="NavTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Divider line between button groups in command bar -->
        <Style x:Key="CmdDivider" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="{DynamicResource BorderStrongBrush}"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Crash recovery banner (collapses when not shown) -->
            <RowDefinition Height="96"/>  <!-- Command bar (tall enough for 84px logo) -->
            <RowDefinition Height="*"/>   <!-- Main area (sidebar + dashboard + file browser) -->
            <RowDefinition Height="32"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             CRASH RECOVERY BANNER — only visible when previous session
             ended uncleanly. One-shot: dismissed or self-clears after export.
             ================================================================ -->
        <Border Grid.Row="0"
                Background="#3A2A1A" BorderBrush="#D49A2A" BorderThickness="0,0,0,1"
                Visibility="{Binding IsCrashBannerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel Margin="12,8">
                <TextBlock DockPanel.Dock="Left" Text="&#x26A0;" FontSize="18"
                           Foreground="#D49A2A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button DockPanel.Dock="Right" Content="Dismiss" Margin="6,0,0,0" Padding="10,3"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding DismissCrashBannerCommand}"/>
                <Button DockPanel.Dock="Right" Content="Export Diagnostics" Padding="10,3"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding ExportDiagnosticsCommand}"/>
                <TextBlock Text="{Binding CrashBannerMessage}"
                           Foreground="#F0D08A" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>
            </DockPanel>
        </Border>

        <!-- ================================================================
             COMMAND BAR — single compact 44px row
             Replaces the oversized logo + two-row layout
             ================================================================ -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">

                <!-- Left: Logo + App Name + version (header.png layout) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Image Source="/Assets/beetle_wizard_circle.png" Width="84" Height="84"
                           Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Beet's Backup"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#9F7CFF" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="v3.0.0" FontSize="11"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Primary "Back up now" button — uses pre-rendered PNG (cropped to button bounds) -->
                <Button DockPanel.Dock="Left" Margin="10,0,4,0" Cursor="Hand"
                        Command="{Binding StartBackupCommand}"
                        ToolTip="Start a manual backup"
                        Background="Transparent" BorderThickness="0"
                        Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Image x:Name="img" Height="38" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <CroppedBitmap SourceRect="268,316,998,324">
                                        <CroppedBitmap.Source>
                                            <BitmapImage UriSource="/Assets/Icons/Toolbar/backup_now_button.png"/>
                                        </CroppedBitmap.Source>
                                    </CroppedBitmap>
                                </Image.Source>
                            </Image>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="img" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="img" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CmdDivider}"/>

                <!-- Transfer controls -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Pause / Resume — sprite button for pause, accent text for resume -->
                    <Button Margin="0,0,2,0"
                            Command="{Binding PauseResumeTransferCommand}"
                            IsEnabled="{Binding IsTransferring}"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Image x:Name="pauseImg" Height="38" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Source>
                                            <CroppedBitmap SourceRect="1047,410,375,159">
                                                <CroppedBitmap.Source>
                                                    <BitmapImage UriSource="/Assets/Icons/Toolbar/toolbar_controls_sprite.png"/>
                                                </CroppedBitmap.Source>
                                            </CroppedBitmap>
                                        </Image.Source>
                                    </Image>
                                    <Border x:Name="resumeContent" Visibility="Collapsed"
                                            Background="{DynamicResource AccentDimBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="13,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="Resume" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="pauseImg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="pauseImg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter TargetName="pauseImg" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="resumeContent" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Stop — sprite button -->
                    <Button Command="{Binding StopTransferCommand}"
                            IsEnabled="{Binding IsTransferring}"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="stopImg" Height="38" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <CroppedBitmap SourceRect="601,410,379,160">
                                            <CroppedBitmap.Source>
                                                <BitmapImage UriSource="/Assets/Icons/Toolbar/toolbar_controls_sprite.png"/>
                                            </CroppedBitmap.Source>
                                        </CroppedBitmap>
                                    </Image.Source>
                                </Image>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="stopImg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="stopImg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CmdDivider}"/>

                <!-- Navigation tools -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Split pane — image button (CroppedBitmap from "split pane.png", region 356,380 825×219) -->
                    <Button ToolTip="Open split pane view" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                            Click="OpenSplitPane_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="splitImg" Height="38" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <CroppedBitmap SourceRect="356,380,825,219">
                                            <CroppedBitmap.Source>
                                                <BitmapImage UriSource="/Assets/Icons/Toolbar/split%20pane.png"/>
                                            </CroppedBitmap.Source>
                                        </CroppedBitmap>
                                    </Image.Source>
                                </Image>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="splitImg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="splitImg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CmdDivider}"/>

                <!-- Feature buttons -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Schedule — sprite button -->
                    <Button Margin="0,0,4,0"
                            Command="{Binding OpenScheduleDialogCommand}"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="schedImg" Height="38" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <CroppedBitmap SourceRect="115,410,412,160">
                                            <CroppedBitmap.Source>
                                                <BitmapImage UriSource="/Assets/Icons/Toolbar/toolbar_controls_sprite.png"/>
                                            </CroppedBitmap.Source>
                                        </CroppedBitmap>
                                    </Image.Source>
                                </Image>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="schedImg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="schedImg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Margin="0,0,4,0" Cursor="Hand" Click="BackupWizard_Click"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="wimg" Height="38" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <CroppedBitmap SourceRect="48,372,612,220">
                                            <CroppedBitmap.Source>
                                                <BitmapImage UriSource="/Assets/Icons/Toolbar/backup_wizard_button.png"/>
                                            </CroppedBitmap.Source>
                                        </CroppedBitmap>
                                    </Image.Source>
                                </Image>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="wimg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="wimg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Jobs" Margin="0,0,4,0"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenJobsDialogCommand}"/>
                    <Button Content="Log" Margin="0,0,4,0"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenLogDialogCommand}"/>
                    <Button x:Name="OptionsButton" Content="Options &#x25BE;" Margin="0,0,4,0"
                            Style="{StaticResource ToolbarButton}"
                            Click="OptionsButton_Click"
                            MouseLeave="OptionsButton_MouseLeave"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Right" Style="{StaticResource CmdDivider}"/>

                <!-- Theme button (both modes) -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding ToggleThemeCommand}"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Theme" Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Visual/List button (both modes) -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding ToggleTopVisualModeCommand}"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE890;"/>
                                    <Setter Property="Foreground">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4CC2FF" Offset="0"/>
                                                <GradientStop Color="#FF6B8A" Offset="0.5"/>
                                                <GradientStop Color="#4ade80" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Visual"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTopVisualMode}" Value="True">
                                            <Setter Property="Text" Value="List"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- Spacer absorbs remaining width -->
                <Border/>

            </DockPanel>
        </Border>

        <!-- Options Popup (stays open until mouse leaves) -->
        <Popup x:Name="OptionsPopup" Grid.Row="1"
               PlacementTarget="{Binding ElementName=OptionsButton}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="4,6"
                    MouseLeave="OptionsPopup_MouseLeave"
                    PreviewKeyDown="OptionsPopup_KeyDown">
                <StackPanel MinWidth="220">
                    <!-- Permissions toggle -->
                    <DockPanel Margin="10,4">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding RemovePermissions}"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Remove Permissions" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <!-- Checksum toggle -->
                    <DockPanel Margin="10,4">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding VerifyChecksums}"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Verify Checksums" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <!-- Throttle toggle -->
                    <DockPanel Margin="10,4"
                               ToolTip="Limit transfer speed to 10 MB/s">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding ThrottleTransfer}"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Throttle (10 MB/s)" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Separator Margin="6,6"/>
                    <!-- Archive Now -->
                    <Button Content="Archive Now"
                            Style="{StaticResource ToolbarButton}"
                            Margin="6,2"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ArchiveNowCommand}"/>
                    <Separator Margin="6,6"/>
                    <!-- Existing options -->
                    <DockPanel Margin="10,4">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding LaunchAtStartup}"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Launch at Startup" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="10,4"
                               ToolTip="When enabled, launching via the Windows Startup shortcut opens to the tray without showing the window.">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding StartMinimized}"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Start Minimized to Tray" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Separator Margin="6,6"/>
                    <Button Content="Check for Updates"
                            Style="{StaticResource ToolbarButton}"
                            Margin="6,2"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CheckForUpdatesCommand}"/>
                    <Button Content="Export Diagnostics for Support..."
                            Style="{StaticResource ToolbarButton}"
                            Margin="6,2"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ExportDiagnosticsCommand}"
                            ToolTip="Save a zip of logs, settings, and system info to your Desktop so you can email it to support."/>
                    <Button Content="View User Guide (FAQ)"
                            Style="{StaticResource ToolbarButton}"
                            Margin="6,2"
                            HorizontalAlignment="Stretch"
                            Click="OpenFaq_Click"
                            ToolTip="Open the Beet's Backup user guide PDF."/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ================================================================
             MAIN AREA
             ================================================================ -->
        <Grid Grid.Row="2">

            <!-- ===== SINGLE PANE ===== -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Drive tree + footer tiles -->
                <Border Grid.Column="0"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <!-- DRIVES header row with inline refresh button -->
                        <Grid DockPanel.Dock="Top" Margin="12,10,8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DRIVES"
                                       FontWeight="Bold" FontSize="12"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource IconButton}"
                                    Command="{Binding RefreshDrivesCommand}"
                                    ToolTip="Refresh drives"
                                    Padding="4" Margin="0" Width="24" Height="24">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <!-- TOTAL CAPACITY footer tile -->
                        <Border DockPanel.Dock="Bottom"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="#3A3075" BorderThickness="1"
                                CornerRadius="10" Margin="8,10,12,10" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="TOTAL CAPACITY" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalCapacityDisplay}" FontSize="20" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <!-- Progress track + proportional fill -->
                                <Grid x:Name="CapacityBar" Margin="0,8,0,6" Height="6">
                                    <Border Background="{DynamicResource ProgressTrackBrush}" CornerRadius="3"/>
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="3"
                                            HorizontalAlignment="Left">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                <Binding ElementName="CapacityBar" Path="ActualWidth"/>
                                                <Binding Path="TotalUsagePercent"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="10.5" Foreground="{DynamicResource SecondaryTextBrush}">
                                        <Run Text="Used: "/><Run Text="{Binding TotalUsedDisplay, Mode=OneWay}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource SecondaryTextBrush}">
                                        <Run Text="Free: "/><Run Text="{Binding TotalFreeDisplay, Mode=OneWay}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TreeView ItemsSource="{Binding TopTreeItems}"
                                  ItemTemplate="{StaticResource FolderTreeTemplate}"
                                  SelectedItemChanged="TopTree_SelectedItemChanged"/>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"/>

                <!-- Right: Status banner + Dashboard cards + Nav bar + File list -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 0: Status banner -->
                        <RowDefinition Height="Auto"/>  <!-- 1: Dashboard cards -->
                        <RowDefinition Height="*"/>     <!-- 2: File browser card -->
                    </Grid.RowDefinitions>

                    <!-- ======= V3 Status Banner — swaps Protected ↔ At Risk via IsProtected ======= -->
                    <Border Grid.Row="0"
                            CornerRadius="10" Margin="10,8,10,0" Padding="18,14"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A0507"/>
                                <Setter Property="BorderBrush" Value="#6E070A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                        <Setter Property="Background" Value="#0A2519"/>
                                        <Setter Property="BorderBrush" Value="#1E5140"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Status icon: green shield+check OR crimson warning triangle+! -->
                            <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,14,0" VerticalAlignment="Center">
                                <!-- Protected: filled green shield with white check -->
                                <Grid Visibility="{Binding IsProtected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Path Fill="#3DD68C" Stretch="Uniform"
                                          Data="M 12,1 L 22,5 L 22,11 C 22,17 18,21 12,23 C 6,21 2,17 2,11 L 2,5 Z"/>
                                    <Path Stroke="White" StrokeThickness="2.4"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Stretch="Uniform" Width="18" Height="18"
                                          Data="M 2,6 L 6,10 L 13,2"/>
                                </Grid>
                                <!-- At Risk: filled crimson warning triangle with white ! -->
                                <Grid Visibility="{Binding IsProtected, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Path Fill="#E04E5C" Stretch="Uniform"
                                          Data="M 12,2 L 23,21 L 1,21 Z"/>
                                    <TextBlock Text="!" Foreground="White" FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="16" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="At risk"/>
                                            <Setter Property="Foreground" Value="#E04E5C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                                    <Setter Property="Text" Value="You are protected"/>
                                                    <Setter Property="Foreground" Value="#3DD68C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Foreground="White" FontSize="11" Margin="0,2,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Your last backup did not complete successfully. Review the log for details."/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                                    <Setter Property="Text" Value="Your last backup completed successfully."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal">
                                    <!-- Last backup -->
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,18,0">
                                        <Run Text="Last backup: " Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Run Text="{Binding LastBackupDisplay, Mode=OneWay}" Foreground="White"/>
                                    </TextBlock>

                                    <!-- Next backup -->
                                    <TextBlock Text="&#xE917;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                        <Run Text="Next backup: " Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Run Text="{Binding NextBackupDisplay, Mode=OneWay}" Foreground="White"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- View details button: outlined rectangular, not a pill -->
                            <Border Grid.Column="2" CornerRadius="6" Padding="12,7"
                                    Background="Transparent"
                                    BorderBrush="#3A5249" BorderThickness="1"
                                    VerticalAlignment="Center" Cursor="Hand"
                                    MouseLeftButtonUp="ViewDetails_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="View details" Foreground="White" FontSize="11.5" FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ======= V3 Dashboard Cards ======= -->
                    <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="6,8,6,4">

                        <!-- ===== Card 1: PROTECTION SUMMARY ===== -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="#3A3075" BorderThickness="1"
                                Margin="4,0" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="PROTECTION SUMMARY" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>

                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource AccentHoverBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="Files backed up" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalFilesCopiedDisplay}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11.5" FontWeight="Medium" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource AccentHoverBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="Total size" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalBytesTransferredDisplay}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11.5" FontWeight="Medium" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource AccentHoverBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="Backups run" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding BackupsRunDisplay}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11.5" FontWeight="Medium" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="#5AE0A4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="Data verified" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11.5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#5AE0A4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Healthy" Foreground="#5AE0A4" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ===== Card 2: BACKUP SCHEDULE ===== -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="#3A3075" BorderThickness="1"
                                Margin="4,0" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="BACKUP SCHEDULE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>

                                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                               Foreground="#F0B860" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Automatic backups" FontSize="10.5"
                                               Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="{Binding ScheduleTimeDisplay}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                    <Border CornerRadius="10" Padding="8,3" Margin="0,8,0,0" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1AF87171"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScheduleEnabled}" Value="True">
                                                        <Setter Property="Background" Value="#1A5AE0A4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#F87171"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsScheduleEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="#5AE0A4"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontSize="10.5" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Not scheduled"/>
                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsScheduleEnabled}" Value="True">
                                                                <Setter Property="Text" Value="Enabled"/>
                                                                <Setter Property="Foreground" Value="#5AE0A4"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Row="2" Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="6"
                                        Padding="10,6" HorizontalAlignment="Stretch" Margin="0,10,0,0" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Edit schedule" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ===== Card 3: WHAT'S INCLUDED ===== -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="#3A3075" BorderThickness="1"
                                Margin="4,0" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="WHAT'S INCLUDED" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>

                                <Grid Grid.Row="1">
                                    <!-- Source paths from configured backup jobs -->
                                    <ItemsControl ItemsSource="{Binding BackupSourcePaths}"
                                                  Visibility="{Binding IsScheduleEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SourcePathItem}">
                                                <Grid Margin="0,3,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                               Foreground="#7C5CFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11.5"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding JobName}"
                                                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="70" Margin="6,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Placeholder when no jobs are configured -->
                                    <TextBlock Text="No backup jobs configured."
                                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsScheduleEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </Grid>

                                <Border Grid.Row="2" Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="6"
                                        Padding="10,6" HorizontalAlignment="Stretch" Margin="0,10,0,0" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Manage backup set" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ===== Card 4: RECENT BACKUPS ===== -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="#3A3075" BorderThickness="1"
                                Margin="4,0" Padding="14,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="RECENT BACKUPS" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="View all" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentHoverBrush}" VerticalAlignment="Center" Cursor="Hand"/>
                                </Grid>

                                <!-- Live backup history rows -->
                                <ItemsControl ItemsSource="{Binding RecentBackups}"
                                              Visibility="{Binding HasRecentBackups, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type m:BackupLogEntry}">
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Status icon -->
                                                <Grid Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse>
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#1AF87171"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                        <Setter Property="Fill" Value="#1A5AE0A4"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="9">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="&#xE711;"/>
                                                                <Setter Property="Foreground" Value="#F87171"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                        <Setter Property="Text" Value="&#xE930;"/>
                                                                        <Setter Property="Foreground" Value="#5AE0A4"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <!-- Date + job name -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeDateConverter}}"
                                                               FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="{Binding JobName}" FontSize="9.5"
                                                               Foreground="{DynamicResource TertiaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <!-- Bytes transferred or failed -->
                                                <TextBlock Grid.Column="2" Text="{Binding SizeOrStatusDisplay}"
                                                           FontSize="10.5" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#F87171"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Placeholder when no backup history exists -->
                                <TextBlock Text="No backup history yet."
                                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"
                                           Visibility="{Binding HasRecentBackups, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- File browser — card container matching dashboard cards, aligned with their borders -->
                    <Border Grid.Row="2" Margin="10,4,10,10"
                            CornerRadius="10" BorderBrush="#3A3075" BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Nav bar: CornerRadius matches the card's top corners so SurfaceInsetBrush
                                 doesn't bleed into the rounded corner areas -->
                            <Border Grid.Row="0" Background="{DynamicResource SurfaceInsetBrush}"
                                    CornerRadius="10,10,0,0"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="&#x25C0;" ToolTip="Back"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoBackCommand}"/>
                            <Button Grid.Column="1" Content="&#x25B6;" ToolTip="Forward"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoForwardCommand}"/>
                            <Button Grid.Column="2" Content="&#x25B2;" ToolTip="Up one level"
                                    Style="{StaticResource NavButton}" Margin="0,0,6,0"
                                    Command="{Binding GoUpCommand}"/>

                            <TextBox Grid.Column="3"
                                     Text="{Binding TopCurrentPath, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource NavTextBox}"/>

                            <Button Grid.Column="4" Content="&#x1F50D;" ToolTip="Search"
                                    Style="{StaticResource NavButton}" Margin="6,0,4,0"
                                    Command="{Binding ExecuteDeepSearchCommand}"/>

                            <Grid Grid.Column="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="SearchBox"
                                         Text="{Binding DeepSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource NavTextBox}"
                                         KeyDown="SearchBox_KeyDown"/>
                                <Button Grid.Column="1" Content="&#x2715;" Padding="4,2" Margin="2,0,0,0"
                                        Style="{StaticResource NavButton}"
                                        Command="{Binding ClearSearchCommand}"
                                        Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Clear search"/>
                            </Grid>
                        </Grid>
                    </Border>

                            <!-- File list area -->
                            <Grid Grid.Row="1">
                        <views:PieChartControl
                            Slices="{Binding TopPieSlices}"
                            TotalSize="{Binding TopTotalSize}"
                            IsCalculating="{Binding IsTopCalculating}"
                            Subtitle="Top 10 largest items"
                            Visibility="{Binding IsTopVisualMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            SliceClicked="TopPieChart_SliceClicked"
                            Panel.ZIndex="1"/>
                        <ListView x:Name="TopPaneList"
                                  Visibility="{Binding IsTopVisualMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                  ItemsSource="{Binding FilteredTopPaneItems}"
                                  Background="{DynamicResource SurfaceBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  MouseDoubleClick="PaneItem_DoubleClick"
                                  GridViewColumnHeader.Click="ColumnHeader_Click"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown"
                                  PreviewMouseLeftButtonUp="Pane_PreviewMouseLeftButtonUp"
                                  PreviewMouseRightButtonDown="Pane_PreviewMouseRightButtonDown"
                                  PreviewMouseMove="Pane_PreviewMouseMove"
                                  Drop="SinglePane_Drop"
                                  DragOver="Pane_DragOver">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="340">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="TopPathColumn" Header="Path" Width="0"
                                                    DisplayMemberBinding="{Binding DirectoryPath}"/>
                                    <GridViewColumn Header="Type" Width="120" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                    <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Header="Modified" Width="160" DisplayMemberBinding="{Binding Modified}"/>
                                    <GridViewColumn Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar IsIndeterminate="True" Height="3" Width="36"
                                                             Foreground="{DynamicResource AccentBrush}"
                                                             Background="{DynamicResource ProgressTrackBrush}"
                                                             BorderThickness="0"
                                                             Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copy" Click="Copy_Click"/>
                                    <MenuItem Header="Cut" Click="Cut_Click"/>
                                    <MenuItem Header="Paste" Click="Paste_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Rename" Click="Rename_Click"/>
                                    <MenuItem Header="Delete" Click="Delete_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Previous Versions..." Click="PreviousVersions_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Extract Here" Click="ExtractHere_Click"/>
                                    <MenuItem Header="Extract To..." Click="ExtractTo_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                        </ListView>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                            <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource ProgressTrackBrush}"
                                         BorderThickness="0" Margin="0,0,0,8"/>
                            <TextBlock Text="Searching..." FontSize="14"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="No results found."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                   IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Split pane is now a separate window (SplitPaneWindow) opened by the toolbar button -->
            <Grid Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>  <!-- Transfer banner -->
                    <RowDefinition Height="4"/>      <!-- Splitter -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP HALF: source tree + nav + file list -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="SOURCE"
                                       FontWeight="Bold" FontSize="12"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="12,10,12,6"/>
                            <TreeView ItemsSource="{Binding TopTreeItems}"
                                      ItemTemplate="{StaticResource FolderTreeTemplate}"
                                      SelectedItemChanged="TopTree_SelectedItemChanged"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"/>

                    <!-- Source pane with left accent border -->
                    <Border Grid.Column="2" BorderBrush="{DynamicResource PaneSrcBorderBrush}"
                            BorderThickness="2,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Source nav bar with SRC badge -->
                            <Border Grid.Row="0" Background="{DynamicResource SurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid Margin="6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- SRC badge -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource PaneSrcBgBrush}"
                                            BorderBrush="{DynamicResource PaneSrcBorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="SOURCE" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>

                                    <Button Grid.Column="1" Content="&#x25C0;" ToolTip="Back"
                                            Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                            Command="{Binding GoBackCommand}"/>
                                    <Button Grid.Column="2" Content="&#x25B6;" ToolTip="Forward"
                                            Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                            Command="{Binding GoForwardCommand}"/>
                                    <Button Grid.Column="3" Content="&#x25B2;" ToolTip="Up one level"
                                            Style="{StaticResource NavButton}" Margin="0,0,6,0"
                                            Command="{Binding GoUpCommand}"/>

                                    <TextBox Grid.Column="4"
                                             Text="{Binding TopCurrentPath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource NavTextBox}"/>
                                </Grid>
                            </Border>

                            <!-- Source file list -->
                            <Grid Grid.Row="1">
                                <Button Content="&#x1F4CA;" Padding="6,4"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ToggleTopVisualModeCommand}"
                                        ToolTip="Toggle data distribution view"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,4,22,0" Panel.ZIndex="2"/>
                                <views:PieChartControl
                                    Slices="{Binding TopPieSlices}"
                                    TotalSize="{Binding TopTotalSize}"
                                    IsCalculating="{Binding IsTopCalculating}"
                                    Subtitle="Top 10 largest items"
                                    Visibility="{Binding IsTopVisualMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                    SliceClicked="TopPieChart_SliceClicked"
                                    Panel.ZIndex="1"/>
                                <ListView x:Name="SplitTopList"
                                          Visibility="{Binding IsTopVisualMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                          ItemsSource="{Binding FilteredTopPaneItems}"
                                          Background="{DynamicResource SurfaceBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderThickness="0"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          MouseDoubleClick="SplitTopItem_DoubleClick"
                                          GridViewColumnHeader.Click="ColumnHeader_Click"
                                          SelectionMode="Extended"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown"
                                          PreviewMouseLeftButtonUp="Pane_PreviewMouseLeftButtonUp"
                                          PreviewMouseRightButtonDown="Pane_PreviewMouseRightButtonDown"
                                          PreviewMouseMove="Pane_PreviewMouseMove"
                                          Drop="SplitTop_Drop"
                                          DragOver="Pane_DragOver">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Name" Width="300">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}">
                                                            <Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn x:Name="SplitTopPathColumn" Header="Path" Width="0"
                                                            DisplayMemberBinding="{Binding DirectoryPath}"/>
                                            <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                            <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            <GridViewColumn Width="50">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ProgressBar IsIndeterminate="True" Height="3" Width="36"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     Background="{DynamicResource ProgressTrackBrush}"
                                                                     BorderThickness="0"
                                                                     Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Copy to Bottom" Click="CopyToBottom_Click"/>
                                            <MenuItem Header="Cut to Bottom" Click="CutToBottom_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Rename" Click="Rename_Click"/>
                                            <MenuItem Header="Delete" Click="Delete_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Previous Versions..." Click="PreviousVersions_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Extract Here" Click="ExtractHere_Click"/>
                                            <MenuItem Header="Extract To..." Click="ExtractTo_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                            IsHitTestVisible="False">
                                    <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="{DynamicResource ProgressTrackBrush}"
                                                 BorderThickness="0" Margin="0,0,0,8"/>
                                    <TextBlock Text="Searching..." FontSize="14"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <TextBlock Text="No results found."
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                                           Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============================================================
                     TRANSFER PROGRESS BANNER (between panes, visible during transfer)
                     ============================================================ -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1"
                        Padding="12,6"
                        Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status text -->
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding StatusMessage}"/>

                        <!-- Progress bar -->
                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Border Background="{DynamicResource ProgressTrackBrush}"
                                    CornerRadius="2" Height="4"/>
                            <ProgressBar Value="{Binding TransferProgressPercent}" Maximum="100"
                                         Height="4" Margin="0"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="Transparent"
                                         BorderThickness="0"/>
                        </Grid>

                        <!-- Percent -->
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{Binding TransferProgressPercent, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>

                        <!-- ETA -->
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding TransferEta}"/>

                        <!-- Inline Pause / Stop controls -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <Button Margin="0,0,4,0"
                                    Command="{Binding PauseResumeTransferCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                        <Setter Property="Content" Value="&#x23F8;"/>
                                        <Setter Property="ToolTip" Value="Pause"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Content" Value="&#x25B6;"/>
                                                <Setter Property="ToolTip" Value="Resume"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="&#x23F9;" ToolTip="Stop"
                                    Style="{StaticResource NavButton}"
                                    Command="{Binding StopTransferCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SPLITTER between top and bottom halves -->
                <GridSplitter Grid.Row="2" Height="4"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderStrongBrush}"/>

                <!-- BOTTOM HALF: destination tree + nav + file list -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="DESTINATION"
                                       FontWeight="Bold" FontSize="12"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="12,10,12,6"/>
                            <TreeView ItemsSource="{Binding BottomTreeItems}"
                                      ItemTemplate="{StaticResource FolderTreeTemplate}"
                                      SelectedItemChanged="BottomTree_SelectedItemChanged"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"/>

                    <!-- Destination pane with left accent border -->
                    <Border Grid.Column="2" BorderBrush="{DynamicResource PaneDstBorderBrush}"
                            BorderThickness="2,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Destination nav bar with DST badge -->
                            <Border Grid.Row="0" Background="{DynamicResource SurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid Margin="6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- DST badge -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource PaneDstBgBrush}"
                                            BorderBrush="{DynamicResource PaneDstBorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="DESTINATION" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"/>
                                    </Border>

                                    <Button Grid.Column="1" Content="&#x25C0;" ToolTip="Back"
                                            Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                            Command="{Binding GoBackBottomCommand}"/>
                                    <Button Grid.Column="2" Content="&#x25B6;" ToolTip="Forward"
                                            Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                            Command="{Binding GoForwardBottomCommand}"/>
                                    <Button Grid.Column="3" Content="&#x25B2;" ToolTip="Up one level"
                                            Style="{StaticResource NavButton}" Margin="0,0,6,0"
                                            Command="{Binding GoUpBottomCommand}"/>

                                    <TextBox Grid.Column="4"
                                             Text="{Binding BottomCurrentPath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource NavTextBox}"/>
                                </Grid>
                            </Border>

                            <!-- Destination file list -->
                            <Grid Grid.Row="1">
                                <views:PieChartControl
                                    Slices="{Binding BottomPieSlices}"
                                    TotalSize="{Binding BottomTotalSize}"
                                    IsCalculating="{Binding IsBottomCalculating}"
                                    Subtitle="Top 10 largest items"
                                    SliceClicked="BottomPieChart_SliceClicked"
                                    Visibility="{Binding IsBottomVisualMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Panel.ZIndex="1"/>
                                <ListView Grid.Column="2" x:Name="SplitBottomList"
                                          Visibility="{Binding IsBottomVisualMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                          ItemsSource="{Binding FilteredBottomPaneItems}"
                                          Background="{DynamicResource SurfaceBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderThickness="0"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          MouseDoubleClick="SplitBottomItem_DoubleClick"
                                          GridViewColumnHeader.Click="ColumnHeader_Click"
                                          SelectionMode="Extended"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown"
                                          PreviewMouseLeftButtonUp="Pane_PreviewMouseLeftButtonUp"
                                          PreviewMouseRightButtonDown="Pane_PreviewMouseRightButtonDown"
                                          PreviewMouseMove="Pane_PreviewMouseMove"
                                          Drop="SplitBottom_Drop"
                                          DragOver="Pane_DragOver">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Name" Width="300">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}">
                                                            <Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn x:Name="SplitBottomPathColumn" Header="Path" Width="0"
                                                            DisplayMemberBinding="{Binding DirectoryPath}"/>
                                            <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                            <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            <GridViewColumn Width="50">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ProgressBar IsIndeterminate="True" Height="3" Width="36"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     Background="{DynamicResource ProgressTrackBrush}"
                                                                     BorderThickness="0"
                                                                     Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Copy to Top" Click="CopyToTop_Click"/>
                                            <MenuItem Header="Cut to Top" Click="CutToTop_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Rename" Click="Rename_Click"/>
                                            <MenuItem Header="Delete" Click="Delete_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Previous Versions..." Click="PreviousVersions_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Extract Here" Click="ExtractHere_Click"/>
                                            <MenuItem Header="Extract To..." Click="ExtractTo_Click"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>

        <!-- ================================================================
             STATUS BAR — clean 28px bar
             ================================================================ -->
        <Border Grid.Row="3"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Visibility="{Binding IsUpdateAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <!-- Update notification banner (replaces status text when update is available) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding UpdateMessage}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="Download" Margin="10,0,0,0" Padding="8,2"
                            Style="{StaticResource ToolbarButton}"
                            Foreground="{DynamicResource AccentBrush}"
                            Command="{Binding OpenUpdatePageCommand}"/>
                    <Button Content="Dismiss" Margin="4,0,0,0" Padding="8,2"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding DismissUpdateCommand}"/>
                </StackPanel>
                <ProgressBar Grid.Column="1"
                             Value="{Binding TransferProgressPercent}"
                             Maximum="100" Width="160" Height="4"
                             Margin="12,0"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource ProgressTrackBrush}"
                             BorderThickness="0"
                             Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding TransferEta}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
