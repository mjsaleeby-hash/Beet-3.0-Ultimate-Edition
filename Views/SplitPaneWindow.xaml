<Window x:Class="BeetsBackup.Views.SplitPaneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:BeetsBackup.Helpers"
        xmlns:views="clr-namespace:BeetsBackup.Views"
        Title="Split Pane — Beet's Backup"
        Icon="/Assets/Beets Backup IMG.ico"
        MinWidth="800" MinHeight="500"
        Width="1400" Height="800"
        FontSize="14"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <h:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <h:UsageToArcConverter x:Key="UsageToArcConverter"/>

        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate x:Key="FolderTreeTemplate" ItemsSource="{Binding Children}">
            <Grid>
                <Border Visibility="{Binding IsDrive, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="#3A3075" BorderThickness="1"
                        CornerRadius="10" Padding="10,8" Margin="0,3,4,3"
                        Width="190" Height="58"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding DriveInfo.UsedSpaceDisplay, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding DriveInfo.TotalSizeDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <Grid Grid.Column="2" Width="36" Height="36" Margin="6,0,0,0"
                              VerticalAlignment="Center" ToolTip="{Binding DriveInfo.FreeSpaceDisplay}">
                            <Ellipse Width="30" Height="30"
                                     Stroke="{DynamicResource RingTrackBrush}" StrokeThickness="3" Fill="Transparent"/>
                            <Path Width="30" Height="30"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="{Binding DriveInfo.UsagePercent, Converter={StaticResource UsageToArcConverter}}"
                                  Fill="Transparent"/>
                            <TextBlock Text="{Binding DriveInfo.UsagePercent, StringFormat={}{0:F0}%}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="9.5" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14"
                           Visibility="{Binding IsDrive, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            </Grid>
        </HierarchicalDataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                 Color="{DynamicResource SelectionColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                 Color="{DynamicResource PrimaryTextColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                 Color="{DynamicResource SelectionColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                 Color="{DynamicResource PrimaryTextColor}"/>
            </Style.Resources>
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="2,0,0,0" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Margin="0,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <Style x:Key="NavTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Transfer banner -->
            <RowDefinition Height="4"/>      <!-- Splitter -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>     <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- TOP HALF: source tree + nav + file list -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SOURCE"
                               FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TertiaryTextBrush}"
                               Margin="12,10,12,6"/>
                    <TreeView ItemsSource="{Binding TopTreeItems}"
                              ItemTemplate="{StaticResource FolderTreeTemplate}"
                              SelectedItemChanged="TopTree_SelectedItemChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <Border Grid.Column="2" BorderBrush="{DynamicResource PaneSrcBorderBrush}"
                    BorderThickness="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SurfaceInsetBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PaneSrcBgBrush}"
                                    BorderBrush="{DynamicResource PaneSrcBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="SOURCE" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Border>
                            <Button Grid.Column="1" Content="&#x25C0;" ToolTip="Back"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoBackCommand}"/>
                            <Button Grid.Column="2" Content="&#x25B6;" ToolTip="Forward"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoForwardCommand}"/>
                            <Button Grid.Column="3" Content="&#x25B2;" ToolTip="Up one level"
                                    Style="{StaticResource NavButton}" Margin="0,0,6,0"
                                    Command="{Binding GoUpCommand}"/>
                            <TextBox Grid.Column="4"
                                     Text="{Binding TopCurrentPath, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource NavTextBox}"/>
                            <Button Grid.Column="5" Content="&#x1F4CA;" ToolTip="Toggle data distribution view"
                                    Style="{StaticResource NavButton}" Margin="4,0,2,0"
                                    Command="{Binding ToggleTopVisualModeCommand}"/>
                            <Button Grid.Column="6" Content="&#x1F50D;" ToolTip="Search"
                                    Style="{StaticResource NavButton}" Margin="2,0,4,0"
                                    Command="{Binding ExecuteDeepSearchCommand}"/>
                            <Grid Grid.Column="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="SearchBox"
                                         Text="{Binding DeepSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource NavTextBox}"
                                         KeyDown="SearchBox_KeyDown"/>
                                <Button Grid.Column="1" Content="&#x2715;" Padding="4,2" Margin="2,0,0,0"
                                        Style="{StaticResource NavButton}"
                                        Command="{Binding ClearSearchCommand}"
                                        Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Clear search"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <views:PieChartControl
                            Slices="{Binding TopPieSlices}"
                            TotalSize="{Binding TopTotalSize}"
                            IsCalculating="{Binding IsTopCalculating}"
                            Subtitle="Top 10 largest items"
                            Visibility="{Binding IsTopVisualMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            SliceClicked="TopPieChart_SliceClicked"
                            Panel.ZIndex="1"/>
                        <ListView x:Name="SplitTopList"
                                  Visibility="{Binding IsTopVisualMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                  ItemsSource="{Binding FilteredTopPaneItems}"
                                  Background="{DynamicResource SurfaceBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  MouseDoubleClick="SplitTopItem_DoubleClick"
                                  GridViewColumnHeader.Click="ColumnHeader_Click"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown"
                                  PreviewMouseLeftButtonUp="Pane_PreviewMouseLeftButtonUp"
                                  PreviewMouseRightButtonDown="Pane_PreviewMouseRightButtonDown"
                                  PreviewMouseMove="Pane_PreviewMouseMove"
                                  Drop="SplitTop_Drop"
                                  DragOver="Pane_DragOver">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="300">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="SplitTopPathColumn" Header="Path" Width="0"
                                                    DisplayMemberBinding="{Binding DirectoryPath}"/>
                                    <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                    <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar IsIndeterminate="True" Height="3" Width="36"
                                                             Foreground="{DynamicResource AccentBrush}"
                                                             Background="{DynamicResource ProgressTrackBrush}"
                                                             BorderThickness="0"
                                                             Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copy to Bottom" Click="CopyToBottom_Click"/>
                                    <MenuItem Header="Cut to Bottom" Click="CutToBottom_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Rename" Click="Rename_Click"/>
                                    <MenuItem Header="Delete" Click="Delete_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Previous Versions..." Click="PreviousVersions_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Extract Here" Click="ExtractHere_Click"/>
                                    <MenuItem Header="Extract To..." Click="ExtractTo_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                        </ListView>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                            <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource ProgressTrackBrush}"
                                         BorderThickness="0" Margin="0,0,0,8"/>
                            <TextBlock Text="Searching..." FontSize="14"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="No results found."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- TRANSFER PROGRESS BANNER (between panes, visible during transfer) -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceRaisedBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1"
                Padding="12,6"
                Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding StatusMessage}"/>
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Background="{DynamicResource ProgressTrackBrush}"
                            CornerRadius="2" Height="4"/>
                    <ProgressBar Value="{Binding TransferProgressPercent}" Maximum="100"
                                 Height="4" Margin="0"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                </Grid>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}">
                    <Run Text="{Binding TransferProgressPercent, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="13"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="{Binding TransferEta}"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Margin="0,0,4,0"
                            Command="{Binding PauseResumeTransferCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Setter Property="Content" Value="&#x23F8;"/>
                                <Setter Property="ToolTip" Value="Pause"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Content" Value="&#x25B6;"/>
                                        <Setter Property="ToolTip" Value="Resume"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="&#x23F9;" ToolTip="Stop"
                            Style="{StaticResource NavButton}"
                            Command="{Binding StopTransferCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SPLITTER between top and bottom halves -->
        <GridSplitter Grid.Row="2" Height="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderStrongBrush}"/>

        <!-- BOTTOM HALF: destination tree + nav + file list -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DESTINATION"
                               FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TertiaryTextBrush}"
                               Margin="12,10,12,6"/>
                    <TreeView ItemsSource="{Binding BottomTreeItems}"
                              ItemTemplate="{StaticResource FolderTreeTemplate}"
                              SelectedItemChanged="BottomTree_SelectedItemChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <Border Grid.Column="2" BorderBrush="{DynamicResource PaneDstBorderBrush}"
                    BorderThickness="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SurfaceInsetBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PaneDstBgBrush}"
                                    BorderBrush="{DynamicResource PaneDstBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="DESTINATION" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"/>
                            </Border>
                            <Button Grid.Column="1" Content="&#x25C0;" ToolTip="Back"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoBackBottomCommand}"/>
                            <Button Grid.Column="2" Content="&#x25B6;" ToolTip="Forward"
                                    Style="{StaticResource NavButton}" Margin="0,0,2,0"
                                    Command="{Binding GoForwardBottomCommand}"/>
                            <Button Grid.Column="3" Content="&#x25B2;" ToolTip="Up one level"
                                    Style="{StaticResource NavButton}" Margin="0,0,6,0"
                                    Command="{Binding GoUpBottomCommand}"/>
                            <TextBox Grid.Column="4"
                                     Text="{Binding BottomCurrentPath, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource NavTextBox}"/>
                            <Button Grid.Column="5" Content="&#x1F4CA;" ToolTip="Toggle data distribution view"
                                    Style="{StaticResource NavButton}" Margin="4,0,2,0"
                                    Command="{Binding ToggleBottomVisualModeCommand}"/>
                            <Button Grid.Column="6" Content="&#x1F50D;" ToolTip="Search"
                                    Style="{StaticResource NavButton}" Margin="2,0,4,0"
                                    Command="{Binding ExecuteBottomDeepSearchCommand}"/>
                            <Grid Grid.Column="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="BottomSearchBox"
                                         Text="{Binding BottomDeepSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource NavTextBox}"
                                         KeyDown="BottomSearchBox_KeyDown"/>
                                <Button Grid.Column="1" Content="&#x2715;" Padding="4,2" Margin="2,0,0,0"
                                        Style="{StaticResource NavButton}"
                                        Command="{Binding ClearBottomSearchCommand}"
                                        Visibility="{Binding HasBottomSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Clear search"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <views:PieChartControl
                            Slices="{Binding BottomPieSlices}"
                            TotalSize="{Binding BottomTotalSize}"
                            IsCalculating="{Binding IsBottomCalculating}"
                            Subtitle="Top 10 largest items"
                            SliceClicked="BottomPieChart_SliceClicked"
                            Visibility="{Binding IsBottomVisualMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            Panel.ZIndex="1"/>
                        <ListView x:Name="SplitBottomList"
                                  Visibility="{Binding IsBottomVisualMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                  ItemsSource="{Binding FilteredBottomPaneItems}"
                                  Background="{DynamicResource SurfaceBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  MouseDoubleClick="SplitBottomItem_DoubleClick"
                                  GridViewColumnHeader.Click="ColumnHeader_Click"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown"
                                  PreviewMouseLeftButtonUp="Pane_PreviewMouseLeftButtonUp"
                                  PreviewMouseRightButtonDown="Pane_PreviewMouseRightButtonDown"
                                  PreviewMouseMove="Pane_PreviewMouseMove"
                                  Drop="SplitBottom_Drop"
                                  DragOver="Pane_DragOver">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="300">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Run Text="{Binding Icon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="SplitBottomPathColumn" Header="Path" Width="0"
                                                    DisplayMemberBinding="{Binding DirectoryPath}"/>
                                    <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                    <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar IsIndeterminate="True" Height="3" Width="36"
                                                             Foreground="{DynamicResource AccentBrush}"
                                                             Background="{DynamicResource ProgressTrackBrush}"
                                                             BorderThickness="0"
                                                             Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copy to Top" Click="CopyToTop_Click"/>
                                    <MenuItem Header="Cut to Top" Click="CutToTop_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Rename" Click="Rename_Click"/>
                                    <MenuItem Header="Delete" Click="Delete_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Previous Versions..." Click="PreviousVersions_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Extract Here" Click="ExtractHere_Click"/>
                                    <MenuItem Header="Extract To..." Click="ExtractTo_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                        </ListView>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsBottomSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                            <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource ProgressTrackBrush}"
                                         BorderThickness="0" Margin="0,0,0,8"/>
                            <TextBlock Text="Searching..." FontSize="14"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="No results found."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding ShowBottomNoResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="4"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding TransferProgressPercent}"
                             Maximum="100" Width="160" Height="4"
                             Margin="12,0"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource ProgressTrackBrush}"
                             BorderThickness="0"
                             Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding TransferEta}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
