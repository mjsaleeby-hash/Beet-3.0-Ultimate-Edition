<Window x:Class="BeetsBackup.Views.TransferProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:BeetsBackup.Helpers"
        Title="Backup in Progress"
        Width="340" Height="420"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13">

    <Window.Resources>
        <h:ProgressToArcConverter x:Key="ProgressToArcConverter"/>

        <!-- Pill-style action button -->
        <Style x:Key="ProgressActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource ProgressActionBtn}">
            <Setter Property="Background" Value="#B00020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B00020"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,20,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Backup in Progress"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="You can close this window — the transfer will keep running."
                       FontSize="11" Margin="0,2,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Ring + centered percent -->
        <Grid Grid.Row="1" Width="200" Height="200"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Track (faint full ring) -->
            <Ellipse Width="172" Height="172"
                     Stroke="{DynamicResource ProgressTrackBrush}"
                     StrokeThickness="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Progress arc -->
            <Path Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="14"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="{Binding TransferProgressPercent, Converter={StaticResource ProgressToArcConverter}}"/>

            <!-- Centered text -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="42" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}">
                    <Run Text="{Binding TransferProgressPercent, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>
                <TextBlock Text="{Binding TransferEta}"
                           HorizontalAlignment="Center" Margin="0,-4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Status message -->
        <TextBlock Grid.Row="2" Margin="0,4,0,14"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxHeight="36"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Style="{StaticResource ProgressActionBtn}"
                    Margin="0,0,8,0"
                    Command="{Binding PauseResumeTransferCommand}">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#x23F8;  Pause"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Text" Value="&#x25B6;  Resume"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
            <Button Style="{StaticResource StopBtn}"
                    Content="&#x23F9;  Stop"
                    Command="{Binding StopTransferCommand}"/>
        </StackPanel>
    </Grid>
</Window>
