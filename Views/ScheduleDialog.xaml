<Window x:Class="BeetsBackup.Views.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Backup"
        Width="580" Height="860"
        MinWidth="480" MinHeight="600"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        FontFamily="Segoe UI Variable, Segoe UI"
        Background="#F3F3F3">

    <!-- Dialog always uses light mode for readability -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="24">
        <!-- Buttons pinned to bottom -->
        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel"
                    Background="#EBEBEB" Foreground="#1A1A1A"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="0,10" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Schedule Backup"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0"
                    Padding="20,10" Cursor="Hand"
                    Click="Schedule_Click"/>
        </Grid>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Job Name -->
                <TextBlock Text="Job Name" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Source -->
                <TextBlock Text="Source Folders / Drives" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <ListBox ItemsSource="{Binding SourcePaths}"
                         SelectedItem="{Binding SelectedSourcePath}"
                         MinHeight="52" MaxHeight="120"
                         Background="White" Foreground="#1A1A1A"
                         BorderBrush="#D0D0D0" BorderThickness="1"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Add Folder"
                            Command="{Binding AddSourceCommand}"
                            Background="#EBEBEB" Foreground="#1A1A1A"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="14,6" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Remove"
                            Command="{Binding RemoveSourceCommand}"
                            Background="#EBEBEB" Foreground="#1A1A1A"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="14,6" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Estimate Size"
                            Command="{Binding EstimateSizeCommand}"
                            Background="#EBEBEB" Foreground="#1A1A1A"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="14,6" Cursor="Hand"
                            ToolTip="Calculate total size of selected sources"/>
                    <TextBlock Text="{Binding SizeEstimate}"
                               Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Pre-flight disk-space message (populated after Estimate Size runs) -->
                <Border CornerRadius="4" Padding="10,8" Margin="0,8,0,0"
                        BorderThickness="1"
                        Visibility="{Binding HasDiskSpaceMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F4F4F4"/>
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInsufficientSpace}" Value="True">
                                    <Setter Property="Background" Value="#FBE5E5"/>
                                    <Setter Property="BorderBrush" Value="#D84040"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsTightSpace}" Value="True">
                                    <Setter Property="Background" Value="#FFF4D6"/>
                                    <Setter Property="BorderBrush" Value="#D89A40"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DiskSpaceMessage}" TextWrapping="Wrap"
                               FontSize="12" Foreground="#1A1A1A"/>
                </Border>

                <!-- Destination -->
                <TextBlock Text="Destination Folder / Drive" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Content="Browse"
                            Command="{Binding BrowseDestinationCommand}"
                            Background="#EBEBEB" Foreground="#1A1A1A"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="14,6" Cursor="Hand"/>
                </Grid>

                <!-- Date and Time -->
                <TextBlock Text="Start Date &amp; Time" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0" SelectedDate="{Binding ScheduledDate}"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Hours}"
                              SelectedItem="{Binding ScheduledHour}"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding Minutes}"
                              SelectedItem="{Binding ScheduledMinute}"/>
                    <ComboBox Grid.Column="6" ItemsSource="{Binding AmPmOptions}"
                              SelectedItem="{Binding SelectedAmPm}"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="72"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Date" Foreground="#6B6B6B" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="Hour" Foreground="#6B6B6B" FontSize="11"/>
                    <TextBlock Grid.Column="4" Text="Minute" Foreground="#6B6B6B" FontSize="11"/>
                    <TextBlock Grid.Column="6" Text="AM / PM" Foreground="#6B6B6B" FontSize="11"/>
                </Grid>

                <!-- Recurring -->
                <StackPanel Orientation="Horizontal" Margin="0,14,0,8">
                    <CheckBox IsChecked="{Binding IsRecurring}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Recurring backup" VerticalAlignment="Center"/>
                </StackPanel>
                <ComboBox ItemsSource="{Binding IntervalOptions}"
                          SelectedItem="{Binding SelectedInterval}"
                          Visibility="{Binding IsRecurring, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Remove Permissions -->
                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <CheckBox IsChecked="{Binding StripPermissions}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Remove permissions on transfer" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Verify Checksums -->
                <StackPanel Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding VerifyChecksums}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Verify file integrity after copy (SHA-256)" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Slower — reads all files after copy to confirm no corruption occurred."
                               Foreground="#6B6B6B" FontSize="11" Margin="24,2,0,0"/>
                </StackPanel>

                <!-- Speed Limit -->
                <StackPanel Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding EnableThrottle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Limit transfer speed" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Slows down the backup so your computer stays responsive for other work — like browsing the web or using other apps while the backup runs in the background."
                               Foreground="#6B6B6B" FontSize="11" TextWrapping="Wrap" Margin="24,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="24,6,0,0"
                                Visibility="{Binding EnableThrottle, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Max speed:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding ThrottleSpeedOptions}"
                                  SelectedItem="{Binding SelectedThrottleSpeed}"
                                  MinWidth="110"/>
                    </StackPanel>
                </StackPanel>

                <!-- Versioning -->
                <StackPanel Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding EnableVersioning}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Keep previous versions of overwritten files" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Before a file is overwritten, its current copy is archived to a hidden .versions folder at the destination root."
                               Foreground="#6B6B6B" FontSize="11" TextWrapping="Wrap" Margin="24,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="24,6,0,0"
                                Visibility="{Binding EnableVersioning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Keep this many versions per file:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                 Width="52" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Compression -->
                <StackPanel Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding EnableCompression}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Compress this backup into a single .zip archive" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Each run produces a timestamped .zip at the destination. Incremental/mirror options do not apply in compressed mode."
                               Foreground="#6B6B6B" FontSize="11" TextWrapping="Wrap" Margin="24,2,0,0"/>
                </StackPanel>

                <!-- Transfer Mode -->
                <TextBlock Text="If files already exist" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <ComboBox ItemsSource="{Binding TransferModeOptions}"
                          SelectedItem="{Binding SelectedTransferMode}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Unknown"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="SkipExisting">
                                                <Setter Property="Text" Value="Skip Existing (Merge)"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="KeepBoth">
                                                <Setter Property="Text" Value="Keep Both"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Replace">
                                                <Setter Property="Text" Value="Replace"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Mirror">
                                                <Setter Property="Text" Value="Mirror (Sync)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Warning: Keep Both on a recurring backup will create duplicate files on each run."
                           Foreground="#D4760A" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                           Visibility="{Binding ShowKeepBothWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <!-- Mirror warning - prominent bordered callout -->
                <Border Background="#FFF4CE" BorderBrush="#D4760A" BorderThickness="1"
                        CornerRadius="4" Padding="10,8" Margin="0,6,0,0"
                        Visibility="{Binding ShowMirrorWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Mirror will permanently delete files from the destination that do not exist in the source — including files you placed there manually. This cannot be undone."
                               Foreground="#8A6D00" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Exclusion Filters -->
                <TextBlock Text="Exclude Files / Folders" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddExclusionCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2" Content="Add"
                            Command="{Binding AddExclusionCommand}"
                            Background="#EBEBEB" Foreground="#1A1A1A"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="14,6" Cursor="Hand"/>
                </Grid>
                <TextBlock Text="e.g. *.tmp, Thumbs.db, node_modules"
                           Foreground="#6B6B6B" FontSize="11" Margin="0,4,0,0"/>
                <ListBox ItemsSource="{Binding ExclusionFilters}"
                         SelectedItem="{Binding SelectedExclusion}"
                         MinHeight="42" MaxHeight="100" Margin="0,6,0,0"
                         Background="White" Foreground="#1A1A1A"
                         BorderBrush="#D0D0D0" BorderThickness="1"/>
                <Button Content="Remove" Margin="0,6,0,0"
                        Command="{Binding RemoveExclusionCommand}"
                        Background="#EBEBEB" Foreground="#1A1A1A"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        Padding="14,6" Cursor="Hand" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
