<Window x:Class="BeetsBackup.Views.MissedBackupsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Missed Backups"
        Width="560" Height="340"
        WindowStartupLocation="CenterScreen"
        FontSize="14"
        FontFamily="Segoe UI Variable, Segoe UI"
        Background="#F3F3F3"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Missed Backups"
                   FontSize="18" FontWeight="SemiBold" Foreground="#1A1A1A"/>

        <TextBlock Grid.Row="2"
                   Text="The following backups were scheduled while the application was closed."
                   Foreground="#555" TextWrapping="Wrap"/>

        <ListView Grid.Row="4" x:Name="MissedList"
                  Background="White"
                  BorderBrush="#D0D0D0"
                  BorderThickness="1"
                  Foreground="#1A1A1A">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Job" Width="160" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Scheduled For" Width="160" DisplayMemberBinding="{Binding NextRun, StringFormat='{}{0:g}'}"/>
                    <GridViewColumn Header="Destination" Width="180" DisplayMemberBinding="{Binding DestinationPath}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Skip All"
                    Background="#EBEBEB" Foreground="#1A1A1A"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="16,8" Margin="0,0,12,0" Cursor="Hand"
                    Click="SkipAll_Click"
                    ToolTip="Skip missed backups and schedule the next run"/>
            <Button Content="Run All Now"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0"
                    Padding="16,8" Cursor="Hand"
                    Click="RunAll_Click"
                    ToolTip="Run all missed backups now"/>
        </StackPanel>
    </Grid>
</Window>
