<Window x:Class="BeetsBackup.Views.PreviousVersionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Previous Versions"
        Width="640" Height="500"
        MinWidth="480" MinHeight="340"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        FontFamily="Segoe UI Variable, Segoe UI"
        Background="#F3F3F3">

    <!-- Dialog always uses light mode for readability, matching ScheduleDialog/JobsDialog. -->
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="24">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Previous Versions" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="#555">
                <Run Text="File:"/>
                <Run Text="{Binding FileName, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
            <TextBlock Text="{Binding LiveFilePath, Mode=OneWay}"
                       FontSize="11" Foreground="#777" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Action buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Restore"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0"
                    Padding="20,8" Cursor="Hand"
                    Click="Restore_Click"/>
            <Button Grid.Column="2" Content="Delete"
                    Background="#EBEBEB" Foreground="#1A1A1A"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="14,8" Cursor="Hand"
                    Click="Delete_Click"/>
            <Button Grid.Column="4" Content="Close"
                    Background="#EBEBEB" Foreground="#1A1A1A"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="20,8" Cursor="Hand"
                    Click="Close_Click"/>
        </Grid>

        <!-- Status line -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                   FontSize="12" Foreground="#555"
                   Margin="0,8,0,0" TextWrapping="Wrap"/>

        <!-- Version list -->
        <ListView ItemsSource="{Binding Versions}"
                  SelectedItem="{Binding SelectedVersion}"
                  MouseDoubleClick="List_DoubleClick">
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    <GridViewColumn Header="Archived" Width="260"
                                    DisplayMemberBinding="{Binding DisplayTimestamp}"/>
                    <GridViewColumn Header="Size" Width="120"
                                    DisplayMemberBinding="{Binding DisplaySize}"/>
                    <GridViewColumn Header="Archive Location" Width="220"
                                    DisplayMemberBinding="{Binding ArchivedPath}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
