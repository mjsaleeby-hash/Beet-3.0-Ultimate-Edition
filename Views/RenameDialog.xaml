<Window x:Class="BeetsBackup.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="400" Height="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        FontFamily="Segoe UI Variable, Segoe UI"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox Grid.Row="0" x:Name="NameBox"
                 Background="White" Foreground="#1A1A1A"
                 BorderBrush="#D0D0D0" BorderThickness="1"
                 Padding="8,6" FontSize="14"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Background="#EBEBEB" Foreground="#1A1A1A"
                    BorderBrush="#D0D0D0" BorderThickness="1" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Content="Rename" Padding="16,8"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
