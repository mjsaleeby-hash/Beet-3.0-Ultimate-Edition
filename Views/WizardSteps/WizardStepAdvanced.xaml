<UserControl x:Class="BeetsBackup.Views.WizardSteps.WizardStepAdvanced"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <StackPanel>
        <!-- Checksums -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding VerifyChecksums}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Verify file integrity after copying" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="26,4,0,0">
                    After each file is copied, Beet's Backup will re-read both the original and the copy and check that they are byte-for-byte identical (SHA-256). This makes the backup roughly twice as slow but guarantees nothing was corrupted.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Permissions -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding StripPermissions}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Remove access restrictions on copied files" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="26,4,0,0">
                    Windows files can be "locked" to a specific user account. Turning this on removes those restrictions so the backed-up files can be opened by anyone on any computer. Useful if you're moving files to a new PC.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Throttle -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding EnableThrottle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Limit transfer speed" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="26,4,0,0">
                    Slows the backup down so your computer stays responsive while it runs. Helpful if you want to keep working during a backup.
                </TextBlock>
                <ComboBox ItemsSource="{Binding ThrottleSpeedOptions}" SelectedItem="{Binding SelectedThrottleSpeed}"
                          Width="120" Margin="26,8,0,0"
                          Visibility="{Binding EnableThrottle, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
        </Border>

        <!-- Exclusions -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Skip certain types of files" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8">
                    Tell the backup to ignore files matching a pattern. For example, "*.tmp" skips temporary files, "Thumbs.db" skips Windows thumbnail caches.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBox Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}" Width="200"
                             Padding="6,4" FontSize="12"/>
                    <Button Content="Add" Padding="10,4" FontSize="12" Margin="6,0,0,0" Cursor="Hand"
                            Command="{Binding AddExclusionCommand}"/>
                    <Button Content="Remove" Padding="10,4" FontSize="12" Margin="6,0,0,0" Cursor="Hand"
                            Command="{Binding RemoveExclusionCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding ExclusionFilters}" SelectedItem="{Binding SelectedExclusion}"
                         MaxHeight="80" FontSize="12"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Skip tip -->
        <Border Background="{DynamicResource SurfaceInsetBrush}" CornerRadius="6" Padding="14,10" Margin="0,4,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                <Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}">&#x1F4A1; Not sure?</Run>
                <Run Text=" Leave everything off and click Next. These options are completely optional — the defaults work great for most people."/>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
