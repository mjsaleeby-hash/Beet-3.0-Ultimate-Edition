<UserControl x:Class="BeetsBackup.Views.WizardSteps.WizardStepDestination"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- THE KEY WARNING: you need a separate drive -->
        <Border Background="#1AFF4444" BorderBrush="#FF6B6B" BorderThickness="1"
                CornerRadius="8" Padding="16,14" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,6">
                    <Run Text="&#x26A0;"/> <Run Text="You need a separate storage device"/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="{DynamicResource PrimaryTextBrush}" LineHeight="20">
                    A backup only protects your files if it's stored on a <Run FontWeight="SemiBold">different drive</Run> than the originals.
                    If your computer's hard drive fails, catches a virus, or gets lost — a backup saved on that same drive is lost too.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,8,0,0" LineHeight="20">
                    Plug in an <Run FontWeight="SemiBold">external hard drive</Run>, a <Run FontWeight="SemiBold">USB flash drive</Run>,
                    or choose a <Run FontWeight="SemiBold">network folder on another computer</Run>.
                    If you don't have a second drive yet, an external USB hard drive is the simplest and most affordable option —
                    you can find them at any electronics store.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0"
                           FontStyle="Italic">
                    Copying files to another folder on the same C: drive is not a backup —
                    it's just a second copy in the same place. If the drive fails, both copies are gone.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Drive picker -->
        <TextBlock Text="Select a destination drive:" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
        <ComboBox ItemsSource="{Binding AvailableDrives}" DisplayMemberPath="Label"
                  SelectedValuePath="RootPath" SelectedValue="{Binding SelectedDrive}"
                  Width="400" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <!-- Optional subfolder -->
        <TextBlock Text="Subfolder (optional):" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Create a folder name like 'My Backups' to keep things organized."
                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6"/>
        <TextBox Text="{Binding Subfolder, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"
                 FontSize="14" Width="400" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <!-- Or browse -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Or:" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Browse for a folder..." Padding="12,6" FontSize="12" Cursor="Hand"
                    Command="{Binding BrowseFolderCommand}"/>
        </StackPanel>

        <!-- Dynamic same-drive warning -->
        <Border Background="#33FF6B6B" BorderBrush="#FF4444" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                Visibility="{Binding ShowSameDriveWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold" Foreground="#FF4444">
                &#x26D4; The destination you selected is on the same drive as your source files.
                This does not protect your data — please choose a different drive.
            </TextBlock>
        </Border>

        <!-- Current selection display -->
        <Border Background="{DynamicResource SurfaceInsetBrush}" CornerRadius="6" Padding="14,10">
            <StackPanel>
                <TextBlock Text="Backup destination:" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding DestinationPath}" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DestinationPath}" Value="">
                                    <Setter Property="Text" Value="No destination selected yet"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
