<UserControl x:Class="BeetsBackup.Views.WizardSteps.WizardStepBackupType"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:steps="clr-namespace:BeetsBackup.ViewModels.WizardSteps">
    <UserControl.Resources>
        <Style x:Key="TypeCard" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder" CornerRadius="8" Padding="16,14"
                                Margin="0,0,0,8" BorderThickness="2"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource SurfaceBrush}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#9B30FF"/>
                                <Setter TargetName="CardBorder" Property="Background" Value="#0D9B30FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <RadioButton Style="{StaticResource TypeCard}"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static steps:BackupType.OneTimeNow}}"
                     GroupName="BackupType">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#x26A1;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Back up right now, just once" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Great for before you install new software, upgrade Windows, or take your laptop somewhere."
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="26,0,0,0"/>
            </StackPanel>
        </RadioButton>

        <RadioButton Style="{StaticResource TypeCard}"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static steps:BackupType.Scheduled}}"
                     GroupName="BackupType">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#x1F4C5;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Back up on a specific date and time" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Schedule it once — for example, tonight at midnight — and the app will run it while you sleep."
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="26,0,0,0"/>
            </StackPanel>
        </RadioButton>

        <RadioButton Style="{StaticResource TypeCard}"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static steps:BackupType.Recurring}}"
                     GroupName="BackupType">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#x1F501;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Back up automatically, on a schedule" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    <Border Background="#9B30FF" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="Recommended" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="The app will back up your files every day, week, or on whatever schedule you choose. Set it and forget it."
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="26,0,0,0"/>
            </StackPanel>
        </RadioButton>

        <!-- Tip -->
        <Border Background="{DynamicResource SurfaceInsetBrush}" CornerRadius="6" Padding="14,10" Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                <Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}">&#x1F4A1; Tip:</Run>
                <Run Text=" Not sure? Choose 'automatically on a schedule' — daily backups mean even if something goes wrong today, yesterday's copy is always safe."/>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
