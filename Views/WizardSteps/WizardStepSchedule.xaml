<UserControl x:Class="BeetsBackup.Views.WizardSteps.WizardStepSchedule"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Job name -->
        <TextBlock Text="Backup name" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="This is just a label so you can find it later in your backup history."
                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6"/>
        <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"
                 FontSize="14" Margin="0,0,0,16"/>

        <!-- Date and time -->
        <TextBlock Text="Start date and time" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <DatePicker SelectedDate="{Binding ScheduledDate}" Width="140" Margin="0,0,12,0"
                        VerticalAlignment="Center"/>
            <TextBox Text="{Binding ScheduledHour, StringFormat=D2}" Width="40" Padding="6,6" TextAlignment="Center"
                     VerticalAlignment="Center"/>
            <TextBlock Text=":" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Text="{Binding ScheduledMinute, StringFormat=D2}" Width="40" Padding="6,6"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AmPmOptions}" SelectedItem="{Binding SelectedAmPm}"
                      Width="60" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Recurrence (only shown for recurring backups) -->
        <TextBlock Text="How often?" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"
                   Visibility="{Binding ShowRecurrence, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <ComboBox ItemsSource="{Binding RecurrenceOptions}" SelectedItem="{Binding SelectedRecurrence}"
                  Width="200" Margin="0,0,0,16"
                  Visibility="{Binding ShowRecurrence, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Tip -->
        <Border Background="{DynamicResource SurfaceInsetBrush}" CornerRadius="6" Padding="14,10">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                <Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}">&#x1F4A1; Tip:</Run>
                <Run Text=" Midnight or early morning (2–4 AM) is a good choice — your computer is idle and the backup won't slow you down. Just make sure your computer is on or set to wake from sleep."/>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
