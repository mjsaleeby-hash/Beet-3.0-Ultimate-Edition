<Window x:Class="BeetsBackup.Views.BackupWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BeetsBackup.ViewModels"
        xmlns:steps="clr-namespace:BeetsBackup.ViewModels.WizardSteps"
        xmlns:wizardViews="clr-namespace:BeetsBackup.Views.WizardSteps"
        Title="Backup Wizard"
        Width="960" Height="620" MinWidth="880" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="14">

    <Window.Resources>
        <!-- Map each step ViewModel to its UserControl -->
        <DataTemplate DataType="{x:Type steps:WizardStepBackupTypeViewModel}">
            <wizardViews:WizardStepBackupType/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepScheduleViewModel}">
            <wizardViews:WizardStepSchedule/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepSourceViewModel}">
            <wizardViews:WizardStepSource/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepDestinationViewModel}">
            <wizardViews:WizardStepDestination/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepTransferModeViewModel}">
            <wizardViews:WizardStepTransferMode/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepAdvancedViewModel}">
            <wizardViews:WizardStepAdvanced/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type steps:WizardStepSummaryViewModel}">
            <wizardViews:WizardStepSummary/>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Wizard button style -->
        <Style x:Key="WizBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizAccentBtn" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="WizFinishBtn" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="#9B30FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#9B30FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ LEFT: WIZARD MASCOT ══════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Glow behind image -->
                <Grid Width="210" Height="210" Margin="0,0,0,0">
                    <Ellipse Width="200" Height="200" Opacity="0.3" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <BlurEffect Radius="20"/>
                        </Ellipse.Effect>
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#9B30FF"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Circular wizard image on top of glow -->
                    <Ellipse Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Assets/beetle_wizard_circle.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
                <!-- Text below the picture -->
                <TextBlock Text="So you want a backup?"
                           FontSize="17" FontWeight="Bold"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="#9B30FF"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </StackPanel>
        </Border>

    <DockPanel Grid.Column="1">
        <!-- ══════════════ HEADER ══════════════ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <!-- Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Background="#1A9B30FF" CornerRadius="6" Padding="8,6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#x2728;" FontSize="20"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Backup Wizard" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="We'll walk you through setting up a backup — step by step."
                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stepper -->
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StepIndicator}">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Active">
                                                    <Setter Property="Background" Value="#9B30FF"/>
                                                    <Setter Property="BorderBrush" Value="#9B30FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Done">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Number}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Active">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Done">
                                                        <Setter Property="Text" Value="&#x2713;"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="11" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Active">
                                                    <Setter Property="Foreground" Value="#9B30FF"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ══════════════ FOOTER ══════════════ -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Button Content="Cancel" HorizontalAlignment="Left"
                        Style="{StaticResource WizBtn}"
                        Command="{Binding CancelCommand}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#x2190; Back" Margin="0,0,8,0"
                            Style="{StaticResource WizBtn}"
                            Command="{Binding BackCommand}"
                            Visibility="{Binding IsFirstStep, Converter={StaticResource InverseBoolVis}}"/>
                    <Button Content="Next &#x2192;"
                            Style="{StaticResource WizAccentBtn}"
                            Command="{Binding NextCommand}"
                            Visibility="{Binding IsLastStep, Converter={StaticResource InverseBoolVis}}"/>
                    <Button Content="{Binding FinishLabel}"
                            Style="{StaticResource WizFinishBtn}"
                            Command="{Binding FinishCommand}"
                            Visibility="{Binding IsLastStep, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════ STEP CONTENT ══════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <!-- Step heading -->
                <TextBlock Text="{Binding StepTitle}" FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding StepDescription}" FontSize="13"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16"
                           TextWrapping="Wrap"/>

                <!-- Dynamic step content -->
                <ContentControl Content="{Binding CurrentStep}"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
    </Grid>
</Window>
